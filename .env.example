# --- Database ---
# SQLite for local development (zero setup). Switch to a Postgres URL in production.
DATABASE_URL="file:./prisma/dev.db"

# --- Anthropic API (required for AI features, from Phase 2 onward) ---
# Create a key at https://console.anthropic.com/ and put it here or in .env.local
ANTHROPIC_API_KEY=""

# --- App secrets ---
# Used to encrypt stored integration tokens (e.g. GitHub PAT) at rest.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CODEIQ_SECRET=""
